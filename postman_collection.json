{
  "info": {
    "name": "Team Task Tracker API",
    "description": "REST API for a team-based task tracker: JWT auth (with refresh rotation), RBAC, task status state machine, filtering/pagination, and Redis-cached task lists.\n\n## Usage\n1. Run `cd backend && docker compose up --build`.\n2. Run **Auth → Login** (seeded admin) — the access token is captured automatically into `{{accessToken}}` and used by every other request.\n3. Run **Projects → Create**, then **Tasks → Create** — the created ids are captured into `{{projectId}}` / `{{taskId}}` so the rest of the requests work without editing.\n\nAll request bodies use the `POST /<resource>/all` list convention with filters in the body.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "accessToken", "value": "" },
    { "key": "adminEmail", "value": "admin@example.com" },
    { "key": "adminPassword", "value": "Admin@12345" },
    { "key": "userId", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Liveness",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Readiness (Postgres + Redis)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/health/ready"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  console.log('accessToken captured');",
                  "}",
                  "pm.test('login ok', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Returns an access token in the body and sets the refresh token as an httpOnly cookie."
          }
        },
        {
          "name": "Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "description": "Rotates the refresh token (sent via httpOnly cookie) and returns a new access token."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "description": "Revokes the current refresh token."
          }
        }
      ]
    },
    {
      "name": "Users (ADMIN)",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"page\": 1,\n  \"limit\": 20,\n  \"role\": \"MEMBER\"\n}"
            },
            "url": "{{baseUrl}}/users/all"
          }
        },
        {
          "name": "Create user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) pm.collectionVariables.set('userId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mary Member\",\n  \"email\": \"mary@example.com\",\n  \"password\": \"Member@123\",\n  \"role\": \"MEMBER\"\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Get user",
          "request": { "method": "GET", "url": "{{baseUrl}}/users/{{userId}}" }
        },
        {
          "name": "Update user",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Mary M.\"\n}" },
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Delete user",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/users/{{userId}}" }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List projects",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"page\": 1,\n  \"limit\": 20,\n  \"search\": \"\"\n}" },
            "url": "{{baseUrl}}/projects/all"
          }
        },
        {
          "name": "Create project",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) pm.collectionVariables.set('projectId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Apollo\",\n  \"description\": \"Launch project\"\n}"
            },
            "url": "{{baseUrl}}/projects"
          }
        },
        {
          "name": "Get project",
          "request": { "method": "GET", "url": "{{baseUrl}}/projects/{{projectId}}" }
        },
        {
          "name": "Update project",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated description\"\n}" },
            "url": "{{baseUrl}}/projects/{{projectId}}"
          }
        },
        {
          "name": "Delete project",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/projects/{{projectId}}" }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List tasks (filter + paginate)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"page\": 1,\n  \"limit\": 20,\n  \"status\": \"TODO\",\n  \"priority\": \"HIGH\",\n  \"assigneeId\": \"{{userId}}\"\n}"
            },
            "url": "{{baseUrl}}/tasks/all",
            "description": "MEMBERs only ever see tasks assigned to them. This list is Redis-cached per assignee."
          }
        },
        {
          "name": "Create task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) pm.collectionVariables.set('taskId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Build login screen\",\n  \"description\": \"OAuth + email\",\n  \"priority\": \"HIGH\",\n  \"projectId\": \"{{projectId}}\",\n  \"assigneeId\": \"{{userId}}\",\n  \"dueDate\": \"2027-01-01\"\n}"
            },
            "url": "{{baseUrl}}/tasks",
            "description": "title is required; dueDate must be a future date. New tasks always start at TODO."
          }
        },
        {
          "name": "Get task",
          "request": { "method": "GET", "url": "{{baseUrl}}/tasks/{{taskId}}" }
        },
        {
          "name": "Update task",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"priority\": \"MEDIUM\",\n  \"description\": \"Updated\"\n}" },
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "description": "MEMBERs may edit their own task's details but cannot reassign or move it, and cannot change status here."
          }
        },
        {
          "name": "Change task status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}" },
            "url": "{{baseUrl}}/tasks/{{taskId}}/status",
            "description": "Enforced transitions: TODO -> IN_PROGRESS -> IN_REVIEW -> DONE; BLOCKED from any active state. Only the assignee or a MANAGER/ADMIN may change status. Illegal transitions return 409 INVALID_TRANSITION."
          }
        },
        {
          "name": "Delete task",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/tasks/{{taskId}}" }
        }
      ]
    }
  ]
}
